{
  "name": "human-numbers-showcase",
  "version": "2.0.0",
  "description": "HumanNumbers Showcase - High-performance .NET number formatting ecosystem demonstration",
  "private": true,
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./wwwroot/css/input.css -o ./wwwroot/css/main.css --minify",
    "watch": "npm run build:css -- --watch",
    "dev": "concurrently \"npm run watch\" \"dotnet run\"",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint \"wwwroot/css/**/*.css\"",
    "lint:js": "eslint \"wwwroot/js/**/*.js\"",
    "format": "prettier --write \"wwwroot/**/*.{css,js}\"",
    "clean": "rimraf wwwroot/css/main.css"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "concurrently": "^8.2.2",
    "stylelint": "^16.1.0",
    "stylelint-config-standard": "^36.0.0",
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.1.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
