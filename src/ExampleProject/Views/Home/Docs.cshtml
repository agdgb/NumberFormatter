1500000.ToHumanCurrency();                    // "$1.5M" (en-US)

// Explicit ISO codes
1500000.ToHumanCurrency("EUR");               // "1.5M EUR"

// Force specific culture
1500000.ToHumanCurrency(culture: new CultureInfo("fr-FR")); // "1,5M €"</code></pre>
                        </div>
