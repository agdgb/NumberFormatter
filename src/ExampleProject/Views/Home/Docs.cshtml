        let currentSection = 'getting-started';

        function showSection(sectionName) {
            // Hide all sections
            document.querySelectorAll('.section-content').forEach(section => {
                section.classList.remove('active');
            });
            
            // Show selected section
            document.getElementById(sectionName).classList.add('active');
            
            // Update TOC
            updateTOC(sectionName);
            
            currentSection = sectionName;
        }

        function updateTOC(sectionName) {
            const tocContainer = document.getElementById('tableOfContents');
            const sectionData = sections[sectionName] || [];
            
            tocContainer.innerHTML = sectionData.map(item => 
                `<a href="#${item.id}" class="toc-item block text-sm text-gray-400 hover:text-blue-400" data-section="${sectionName}">${item.title}</a>`
            ).join('');
        }

        function showTab(event, tabName) {
            // Hide all tab contents
            const tabContents = document.querySelectorAll('.tab-content');
            tabContents.forEach(content => content.classList.add('hidden'));
            
            // Remove active class from all tab buttons
            const tabButtons = document.querySelectorAll('.tab-button');
            tabButtons.forEach(button => button.classList.remove('active'));
            
            // Show selected tab content
            const selectedTab = document.getElementById(tabName);
            if (selectedTab) {
                selectedTab.classList.remove('hidden');
            }
            
            // Add active class to clicked button
            event.target.classList.add('active');
        }

        // Progress bar
        function updateProgressBar() {
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrollPercent = (scrollTop / scrollHeight) * 100;
            document.getElementById('progressBar').style.width = scrollPercent + '%';
        }

        // Scroll spy for both TOC and navigation sidebar
        function updateScrollSpy() {
            const currentSectionElement = document.querySelector('.section-content.active');
            if (!currentSectionElement) return;
            
            const sectionId = currentSectionElement.getAttribute('id');
            const subSections = currentSectionElement.querySelectorAll('section[id]');
            const tocLinks = document.querySelectorAll('.toc-item');
            const navLinks = document.querySelectorAll('.nav-item');
            
            let current = sectionId;
            const scrollPosition = window.scrollY || document.documentElement.scrollTop;
            
            subSections.forEach(section => {
                // Use 150px offset to trigger slightly before the section reaches the top
                if (scrollPosition >= (section.offsetTop - 150)) {
                    current = section.getAttribute('id');
                }
            });
            
            // Update TOC links
            tocLinks.forEach(link => {
                const href = link.getAttribute('href');
                if (href === `#${current}`) {
                    link.classList.add('active', 'text-blue-400');
                    link.classList.remove('text-gray-400');
                } else {
                    link.classList.remove('active', 'text-blue-400');
                    link.classList.add('text-gray-400');
                }
            });

            // Update Navigation links in left sidebar
            navLinks.forEach(link => {
                const href = link.getAttribute('href');
                const linkSection = link.getAttribute('data-section');
                
                let isActive = (href === `#${current}`);
                
                // Fallback: If current is the main section ID, mark the first link in that section as active
                // (This handles "Overview" links that might point to a sub-section ID like #core-overview)
                if (!isActive && current === sectionId && linkSection === sectionId) {
                    const firstInSection = document.querySelector(`.nav-item[data-section="${sectionId}"]`);
                    if (link === firstInSection) {
                        isActive = true;
                    }
                }
                
                if (isActive) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });
        }

        // Navigation click handlers
        document.addEventListener('click', function(e) {
            // Handle section navigation
            if (e.target.classList.contains('nav-item')) {
                e.preventDefault();
                const sectionName = e.target.getAttribute('data-section');
                const href = e.target.getAttribute('href');
                
                // Show the section
                showSection(sectionName);
                
                // Remove active class from all nav items
                document.querySelectorAll('.nav-item').forEach(item => {
                    item.classList.remove('active');
                });
                
                // Add active class only to the clicked item
                e.target.classList.add('active');
                
                // If clicking on an overview link, scroll to top of section
                if (href && href.startsWith('#')) {
                    const targetId = href.substring(1);
                    const targetElement = document.getElementById(targetId);
                    if (targetElement) {
                        setTimeout(() => {
                            targetElement.scrollIntoView({
                                behavior: 'smooth',
                                block: 'start'
                            });
                        }, 100);
                    }
                }
                return;
            }
            
            // Handle TOC links
            if (e.target.classList.contains('toc-item')) {
                e.preventDefault();
                const targetId = e.target.getAttribute('href').substring(1);
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    targetElement.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
                return;
            }
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                if (anchor.classList.contains('nav-item') || anchor.classList.contains('toc-item')) return;
                
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Scroll event listeners
        window.addEventListener('scroll', () => {
            updateProgressBar();
            updateScrollSpy();
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            showSection('getting-started');
            updateProgressBar();
            updateScrollSpy();
        });

        // Handle browser back/forward
        window.addEventListener('popstate', (e) => {
            if (e.state && e.state.section) {
                showSection(e.state.section);
            }
        });

        // Update URL on section change
        function updateURL(sectionName) {
            const url = new URL(window.location);
            url.hash = sectionName;
            window.history.pushState({ section: sectionName }, '', url);
        }
    </script>
