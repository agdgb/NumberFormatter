    if (_formatCache.TryGetValue(cacheKey, out var cached))
        return cached.ToString();
    
    var formatted = value.ToHuman(culture);
    _formatCache.TryAdd(cacheKey, new NumberFormatInfo { /* ... */ });
    return formatted;
}

