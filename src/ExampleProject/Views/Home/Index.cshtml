</section>

@section Scripts {
    <script>
        // Utility: Copy to Clipboard with Tooltip
        function copySnippet(id) {
            const text = document.getElementById(id).innerText;
            const btn = event.currentTarget;
            const tooltip = btn.querySelector('.copy-tooltip');
            
            navigator.clipboard.writeText(text).then(() => {
                // Show tooltip
                if (tooltip) {
                    tooltip.classList.remove('opacity-0', '-translate-y-2');
                    tooltip.classList.add('opacity-100', '-translate-y-8');
                    
                    setTimeout(() => {
                        tooltip.classList.add('opacity-0', '-translate-y-2');
                        tooltip.classList.remove('opacity-100', '-translate-y-8');
                    }, 2000);
                }

                // Temporary icon change
                const originalSvg = btn.innerHTML;
                const checkSvg = '<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
                
                // If there's a tooltip, we need to preserve it during the icon swap
                const tooltipHtml = tooltip ? tooltip.outerHTML : '';
                btn.innerHTML = checkSvg + tooltipHtml;
                
                setTimeout(() => {
                    btn.innerHTML = originalSvg;
                }, 2000);
            });
        }

        // Roman Numeral Converter
        async function convertRoman() {
            const val = document.getElementById('romanInput').value;
            const resContainer = document.getElementById('romanResultContainer');
            const output = document.getElementById('romanOutput');
            const codeEl = document.getElementById('romanCodePreview');
            
            codeEl.innerText = `${val}.ToRoman();`;

            try {
                const response = await fetch(`/api/demo/roman/${val}`);
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);

                output.innerText = data.roman;
                resContainer.classList.remove('hidden');
                resContainer.classList.add('animate-fade-in');
            } catch (e) {
                console.error("Roman Error:", e);
            }
        }

        // Byte Size Converter
        async function convertBytes() {
            const val = document.getElementById('byteInput').value;
            const binary = document.getElementById('binaryToggle').checked;
            const resContainer = document.getElementById('byteResultContainer');
            const output = document.getElementById('byteOutput');
            const label = document.getElementById('byteLabel');
            const codeEl = document.getElementById('byteCodePreview');
            
            codeEl.innerText = `${val}.ToHumanBytes(useBinaryPrefixes: ${binary});`;

            try {
                const response = await fetch(`/api/demo/bytes/${val}?binary=${binary}`);
                const data = await response.json();
                
                label.innerText = data.type;
                output.innerText = data.formatted;
                resContainer.classList.remove('hidden');
                resContainer.classList.add('animate-fade-in');
            } catch (e) {
                console.error("Byte Error:", e);
            }
        }

        // Parser
        async function executeParse() {
            const input = document.getElementById('parseInput').value;
            const culture = document.getElementById('parseCulture').value;
            const resContainer = document.getElementById('parseResultContainer');
            const output = document.getElementById('parseOutput');
            const codeEl = document.getElementById('parseCodePreview');
            
            const cultureArg = culture ? `, new CultureInfo("${culture}")` : '';
            codeEl.innerText = `HumanNumber.Parse("${input}"${cultureArg});`;

            try {
                const url = `/api/demo/parse?input=${encodeURIComponent(input)}&culture=${culture}`;
                const response = await fetch(url);
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);

                output.innerText = data.parsedValue;
                resContainer.classList.remove('hidden');
                resContainer.classList.add('animate-scale-in');
            } catch (e) {
                console.error("Parse Error:", e);
            }
        }

        function setParsePreset(txt, culture = '') {
            document.getElementById('parseInput').value = txt;
            document.getElementById('parseCulture').value = culture;
            executeParse();
        }

        // Policy Lab
        async function fetchPolicies() {
            const select = document.getElementById('policySelect');
            try {
                const response = await fetch('/api/demo/policies');
                const policies = await response.json();
                select.innerHTML = '';
                policies.forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p;
                    opt.innerText = p;
                    select.appendChild(opt);
                });
                executePolicyLab();
            } catch (e) {
                console.error("Failed to fetch policies", e);
            }
        }

        function setPolicyMode(mode) {
            const current = document.getElementById('currentPolicyMode').value;
            const btnNum = document.getElementById('btn-mode-number');
            const btnCur = document.getElementById('btn-mode-currency');
            const btnWords = document.getElementById('btn-mode-words');
            
            if (mode === 'number') {
                // Clicking number disables everything else
                document.getElementById('currentPolicyMode').value = 'number';
            } else if (mode === 'currency') {
                // Clicking currency keeps words if it was already selected, but disables number
                // However, since DemoController only takes one mode, we prioritize the click
                document.getElementById('currentPolicyMode').value = 'currency';
            } else if (mode === 'words') {
                // Clicking words activates ONLY itself and inactivates others
                document.getElementById('currentPolicyMode').value = 'words';
            }
            
            updateModeButtons();
            executePolicyLab();
        }

        function updateModeButtons() {
            const mode = document.getElementById('currentPolicyMode').value;
            const buttons = ['number', 'currency', 'words'];
            
            buttons.forEach(m => {
                const btn = document.getElementById(`btn-mode-${m}`);
                if (m === mode) {
                    btn.classList.add('bg-blue-600', 'text-white', 'border-transparent', 'active');
                    btn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-400', 'border-gray-200', 'dark:border-gray-700');
                } else {
                    btn.classList.remove('bg-blue-600', 'text-white', 'border-transparent', 'active');
                    btn.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-400', 'border-gray-200', 'dark:border-gray-700');
                }
            });
        }

        async function executePolicyLab() {
            const val = document.getElementById('policyValue').value;
            const policy = document.getElementById('policySelect').value;
            const mode = document.getElementById('currentPolicyMode').value;
            const alwaysShowSuffix = document.getElementById('alwaysSuffixToggle').checked;
            const threshold = document.getElementById('thresholdOverride').value;
            const output = document.getElementById('policyOutput');
            const details = document.getElementById('policyDetails');
            const codeEl = document.getElementById('policyCodePreview');

            if (!val) {
                output.innerText = "...";
                return;
            }

            // Construct Code Preview
            let code = `HumanNumber.Format(${val})`;
            if (policy !== "Default") code += `.UsingPolicy("${policy}")`;
            if (alwaysShowSuffix) code += `.UsingOptions(o => o.AlwaysShowSuffix = true)`;
            if (threshold) code += `.UsingOptions(o => o.Threshold = ${threshold}m)`;
            
            if (mode === 'currency') code += '.ToHumanCurrency()';
            else if (mode === 'words') code += '.ToHumanWords()';
            else code += '.ToHuman()';
            
            codeEl.innerText = code;

            details.style.opacity = '0.5';
            
            try {
                let url = `/api/demo/format-policy?value=${val}&policy=${policy}&mode=${mode}&alwaysShowSuffix=${alwaysShowSuffix}`;
                if (threshold) url += `&threshold=${threshold}`;

                const response = await fetch(url);
                const data = await response.json();
                
                output.innerText = data.formatted;
                
                // Update Technical Context
                document.getElementById('detailThreshold').innerText = new Intl.NumberFormat().format(data.details.threshold);
                document.getElementById('detailPrecision').innerText = data.details.decimalPlaces;
                
                const suffixList = document.getElementById('detailSuffixList');
                suffixList.innerHTML = '';
                data.details.suffixes.forEach(s => {
                    const item = document.createElement('div');
                    item.className = 'flex justify-between items-center py-2 border-b border-gray-800';
                    item.innerHTML = `<span class="text-xs text-gray-500 dark:text-gray-400">>= ${new Intl.NumberFormat().format(s.threshold)}</span> <span class="inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700 bg-blue-600 text-white border-transparent">${s.suffix || 'None'}</span>`;
                    suffixList.appendChild(item);
                });

            } catch (e) {
                console.error("Policy formatting failed", e);
            } finally {
                details.style.opacity = '1';
            }
        }

        // Financial Playground
        function loadPreset(type) {
            const el = document.getElementById('financialInput');
            if (type === 'golden') {
                el.value = '{\n  "spread": "125 bps",\n  "treasuryPrice": "101 16/32",\n  "rawAmount": 5432.10\n}';
            } else if (type === 'negative') {
                el.value = '{\n  "spread": "-50 bps",\n  "treasuryPrice": "99 1/32",\n  "rawAmount": -1000.00\n}';
            }
        }

        async function executePlayground() {
            const inputTxt = document.getElementById('financialInput').value;
            const resEl = document.getElementById('financialResult');
            const badge = document.getElementById('matchBadge');
            const errBox = document.getElementById('financialErrorBox');
            const errTxt = document.getElementById('financialErrorText');

            errBox.classList.add('hidden');
            resEl.innerText = "Processing binding...";
            
            try {
                const response = await fetch('/api/demo/financial', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: inputTxt
                });
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);

                resEl.innerText = JSON.stringify(data, null, 2);
                if (data.roundtripMatch) {
                    badge.className = "inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-cyan-500/20 text-cyan-800 dark:text-cyan-300 border border-cyan-500/30";
                    badge.innerText = "Perfect Roundtrip";
                } else {
                    badge.className = "inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-amber-500/20 text-amber-800 dark:text-amber-300 border border-amber-500/30";
                    badge.innerText = "Content Changed";
                }
            } catch (e) {
                errTxt.innerText = e.message;
                errBox.classList.remove('hidden');
                resEl.innerText = "// Deserialization Error";
                badge.className = "inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-red-500/20 text-red-800 dark:text-red-300 border border-red-500/30";
                badge.innerText = "Fatal Error";
            }
        }

        // Financial Labs
        async function executeBpsLab() {
            const val = document.getElementById('bpsInput').value;
            const output = document.getElementById('bpsOutput');
            const codeEl = document.getElementById('bpsCodePreview');
            
            codeEl.innerText = `${val}m.ToHumanBps();`;
            
            try {
                const response = await fetch(`/api/demo/bps?value=${val}`);
                const data = await response.json();
                output.innerText = data.formatted;
            } catch (e) { console.error(e); }
        }

        async function executeFractionLab() {
            const val = document.getElementById('fractionInput').value;
            const den = document.getElementById('fractionDenominator').value;
            const output = document.getElementById('fractionOutput');
            const codeEl = document.getElementById('fractionCodePreview');
            
            codeEl.innerText = `${val}m.ToHumanFraction(${den});`;
            
            try {
                const response = await fetch(`/api/demo/fraction?value=${val}&denominator=${den}`);
                const data = await response.json();
                output.innerText = data.formatted;
            } catch (e) { console.error(e); }
        }

        async function executeWordsLab() {
            const val = document.getElementById('wordsInput').value;
            const output = document.getElementById('wordsOutput');
            const codeEl = document.getElementById('wordsCodePreview');
            
            codeEl.innerText = `${val}m.ToHumanWords("Dollars");`;
            
            try {
                const response = await fetch(`/api/demo/words?value=${val}&major=Dollars&singular=Dollar`);
                const data = await response.json();
                output.innerText = data.formatted;
            } catch (e) { console.error(e); }
        }

        // Initialize on load
        window.addEventListener('DOMContentLoaded', () => {
            fetchPolicies();
            executeBpsLab();
            executeFractionLab();
            executeWordsLab();
        });
    </script>
}