@addTagHelper *, HumanNumbers.AspNetCore

@{
    ViewData["Title"] = "HumanNumbers Showcase";
    Layout = "_Layout";
}

@using HumanNumbers
@using System.Globalization

<!-- Hero Section -->
<section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-4xl mx-auto">
            <!-- Badge -->
            <div class="inline-flex items-center space-x-2 mb-6">
                <span class="inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700 bg-blue-600 text-white border-transparent">v2.0.0-preview.1</span>
                <span class="inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700">Zero-Allocation</span>
                <span class="inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700">Culture-Aware</span>
            </div>
            
            <!-- Main Title -->
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-6">
                <span class="font-brand font-extrabold bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent transform-gpu">HumanNumbers</span> Showcase
            </h1>
            
            <!-- Subtitle -->
            <p class="text-xl text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">
                Exhaustive technical demonstration of the high-performance, culture-aware .NET number formatting ecosystem
            </p>
            
            <!-- Quick Stats -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto mb-12">
                <div class="text-center p-4 rounded-2xl bg-white dark:bg-gray-800/50 border border-gray-100 dark:border-gray-800 shadow-sm">
                    <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">~170ns</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400 font-medium">Formatting Time</div>
                </div>
                <div class="text-center p-4 rounded-2xl bg-white dark:bg-gray-800/50 border border-gray-100 dark:border-gray-800 shadow-sm">
                    <div class="text-2xl font-bold text-cyan-600 dark:text-cyan-400">56 B</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400 font-medium">Base Allocations</div>
                </div>
                <div class="text-center p-4 rounded-2xl bg-white dark:bg-gray-800/50 border border-gray-100 dark:border-gray-800 shadow-sm">
                    <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">.NET Standard 2.0+</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400 font-medium">Compatible</div>
                </div>
                <div class="text-center p-4 rounded-2xl bg-white dark:bg-gray-800/50 border border-gray-100 dark:border-gray-800 shadow-sm">
                    <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">Full I18N</div>
                    <div class="text-sm text-gray-500 dark:text-gray-400 font-medium">Cultures Supported</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Start Section -->
<section id="quick-start" class="py-12 px-4 sm:px-6 lg:px-8 border-b border-gray-100 dark:border-gray-800">
    <div class="max-w-7xl mx-auto">
        <div class="flex items-center space-x-4 mb-8">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Quick Start Reference</h2>
            <div class="h-px flex-1 bg-gray-100 dark:bg-gray-800"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Basic Usage -->
            <div class="group relative bg-white dark:bg-gray-900 rounded-2xl p-5 border border-gray-200 dark:border-gray-800 hover:border-blue-500/50 transition-all duration-300">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest">Basics</span>
                    <button onclick="copySnippet('basic-code')" class="relative p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors text-gray-400 hover:text-blue-500">
                        <span class="copy-tooltip absolute left-1/2 -translate-x-1/2 px-2 py-1 bg-gray-900 text-white text-[10px] font-bold rounded opacity-0 pointer-events-none transition-all duration-200">Copied!</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-3 8h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    </button>
                </div>
                <div class="bg-gray-50 dark:bg-black/40 rounded-xl p-4 font-mono text-sm overflow-hidden">
                    <pre id="basic-code" class="text-gray-800 dark:text-blue-100">1234567m.ToHuman(); <span class="text-gray-500">// "1.23M"</span></pre>
                </div>
            </div>

            <!-- Currency -->
            <div class="group relative bg-white dark:bg-gray-900 rounded-2xl p-5 border border-gray-200 dark:border-gray-800 hover:border-cyan-500/50 transition-all duration-300">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-widest">Currency</span>
                    <button onclick="copySnippet('currency-code')" class="relative p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors text-gray-400 hover:text-cyan-500">
                        <span class="copy-tooltip absolute left-1/2 -translate-x-1/2 px-2 py-1 bg-gray-900 text-white text-[10px] font-bold rounded opacity-0 pointer-events-none transition-all duration-200">Copied!</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-3 8h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    </button>
                </div>
                <div class="bg-gray-50 dark:bg-black/40 rounded-xl p-4 font-mono text-sm overflow-hidden">
                    <pre id="currency-code" class="text-gray-800 dark:text-cyan-100">val.ToHumanCurrency("USD"); <span class="text-gray-500">// "$1.23M"</span></pre>
                </div>
            </div>

            <!-- Fluent API -->
            <div class="group relative bg-white dark:bg-gray-900 rounded-2xl p-5 border border-gray-200 dark:border-gray-800 hover:border-purple-500/50 transition-all duration-300">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-bold text-purple-600 dark:text-purple-400 uppercase tracking-widest">Fluent API</span>
                    <button onclick="copySnippet('fluent-code')" class="relative p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors text-gray-400 hover:text-purple-500">
                        <span class="copy-tooltip absolute left-1/2 -translate-x-1/2 px-2 py-1 bg-gray-900 text-white text-[10px] font-bold rounded opacity-0 pointer-events-none transition-all duration-200">Copied!</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-3 8h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    </button>
                </div>
                <div class="bg-gray-50 dark:bg-black/40 rounded-xl p-4 font-mono text-sm overflow-hidden">
                    <pre id="fluent-code" class="text-gray-800 dark:text-purple-100">HumanNumber.Format(val).Strict().ToHuman();</pre>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Interactive Labs Section -->
<section id="features" class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-900/30">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Interactive Labs</h2>
            <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
                Explore the full capabilities of <span class="font-brand font-bold bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent">HumanNumbers</span> through hands-on demonstrations
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Roman Numeral Lab -->
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-lg transition-all duration-200 hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-xl hover:-translate-y-0.5 p-6">
                <div class="flex items-center space-x-3 mb-4">
                    <div class="w-10 h-10 bg-linear-to-br from-human-primary to-human-primary-dark rounded-lg flex items-center justify-center">
                        <span class="text-gray-900 dark:text-white font-bold text-sm">#</span>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Roman Numeral Lab</h3>
                </div>
                
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">Convert integers to Roman numerals (1-3999)</p>
                
                <div class="space-y-4">
                    <div class="flex space-x-3">
                        <input type="number" id="romanInput" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 flex-1" value="2024" min="1" max="3999">
                        <button onclick="convertRoman()" class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950 border border-transparent cursor-pointer bg-blue-600 text-white hover:bg-blue-700 shadow-md hover:shadow-lg px-6">
                            Convert
                        </button>
                    </div>
                    
                    <div id="romanResultContainer" class="hidden">
                        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-4 text-center">
                            <span class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Roman Output</span>
                            <div id="romanOutput" class="text-2xl font-bold text-blue-600 dark:text-blue-400 mt-1"></div>
                        </div>
                        <div class="mt-4 p-3 bg-gray-900 dark:bg-black/40 rounded-lg font-mono text-[10px] border border-gray-800 shadow-inner">
                            <span class="text-blue-400">var</span> <span class="text-gray-300">result = </span><span id="romanCodePreview" class="text-blue-200"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Byte Size Lab -->
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-lg transition-all duration-200 hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-xl hover:-translate-y-0.5 p-6">
                <div class="flex items-center space-x-3 mb-4">
                    <div class="w-10 h-10 bg-linear-to-br from-vercel-cyan to-cyan-600 rounded-lg flex items-center justify-center">
                        <span class="text-gray-900 font-bold text-sm">💾</span>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Byte Size Formatter</h3>
                </div>
                
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">Defaulting to IEC (Binary) prefixes for precise developer presentation</p>
                
                <div class="space-y-4">
                    <div class="flex space-x-3">
                        <input type="number" id="byteInput" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 flex-1" value="5368709120" min="0" oninput="convertBytes()">
                        <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-800 rounded-lg px-3 py-2">
                            <input type="checkbox" id="binaryToggle" class="w-4 h-4 text-blue-600 dark:text-blue-400 bg-gray-700 border-gray-600 rounded focus:ring-vercel-blue focus:ring-2" checked onchange="convertBytes()">
                            <label for="binaryToggle" class="text-sm text-gray-700 dark:text-gray-300 cursor-pointer">IEC/Binary</label>
                        </div>
                        <button onclick="convertBytes()" class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950 border border-transparent cursor-pointer bg-blue-600 text-white hover:bg-blue-700 shadow-md hover:shadow-lg px-6">
                            Scale
                        </button>
                    </div>
                    
                    <div id="byteResultContainer" class="hidden">
                        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-4 text-center">
                            <span id="byteLabel" class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider">Human-Readable Size</span>
                            <div id="byteOutput" class="text-2xl font-bold text-cyan-600 dark:text-cyan-400 mt-1"></div>
                        </div>
                        <div class="mt-4 p-3 bg-gray-900 dark:bg-black/40 rounded-lg font-mono text-[10px] border border-gray-800 shadow-inner">
                            <span class="text-blue-400">var</span> <span class="text-gray-300">size = </span><span id="byteCodePreview" class="text-blue-200"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Connector -->
<div class="relative h-20 bg-gradient-to-b from-transparent via-gray-100 dark:via-gray-900/50 to-transparent"></div>

<!-- Parsing Lab Section -->
<section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <div class="max-w-4xl mx-auto">
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-lg transition-all duration-200 p-8">
                <div class="text-center mb-8">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Robust Parsing Lab</h3>
                    <p class="text-gray-600 dark:text-gray-400">
                        Demonstrating <code class="text-blue-600 dark:text-blue-400 bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded">HumanNumber.Parse</code> 
                        with round-trip support for formatted strings
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Formatted Input</label>
                        <input type="text" id="parseInput" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" value="1.5M" placeholder="e.g. 1.5M, $50k, 1,250.50">
                        <div class="flex gap-2 mt-2">
                            <button onclick="setParsePreset('1.5M')" class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950 border border-transparent cursor-pointer bg-transparent text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white text-xs px-3 py-1 hover:bg-gray-800">1.5M</button>
                            <button onclick="setParsePreset('$50.25k')" class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950 border border-transparent cursor-pointer bg-transparent text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white text-xs px-3 py-1 hover:bg-gray-800">$50.25k</button>
                            <button onclick="setParsePreset('1,5k', 'fr-FR')" class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950 border border-transparent cursor-pointer bg-transparent text-gray-700 dark:text-gray-300 border-gray-300 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white text-xs px-3 py-1 hover:bg-gray-800">1,5k (FR)</button>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Culture</label>
                        <select id="parseCulture" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 cursor-pointer">
                            <option value="">Invariant / US</option>
                            <option value="fr-FR">French (fr-FR)</option>
                            <option value="de-DE">German (de-DE)</option>
                            <option value="en-GB">British (en-GB)</option>
                        </select>
                    </div>
                    
                    <div class="flex items-end">
                        <button onclick="executeParse()" class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ease-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950 border border-transparent cursor-pointer bg-blue-600 text-white hover:bg-blue-700 shadow-md hover:shadow-lg w-full">
                            Resolve
                        </button>
                    </div>
                </div>
                
                <div id="parseResultContainer" class="hidden">
                    <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-6 text-center border border-vercel-blue/20">
                        <div class="inline-flex items-center justify-center w-12 h-12 bg-vercel-blue/10 rounded-full mb-3">
                            <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Resolved Decimal Value</div>
                        <div id="parseOutput" class="text-3xl font-bold text-gray-900 dark:text-white"></div>
                        
                        <div class="mt-6 p-3 bg-gray-900 dark:bg-black/40 rounded-lg font-mono text-[10px] border border-gray-800 text-left shadow-inner">
                            <span class="text-blue-400">decimal</span> <span class="text-gray-300">val = </span><span id="parseCodePreview" class="text-blue-200"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Connector -->
<div class="relative h-20 bg-gradient-to-b from-transparent via-gray-100 dark:via-gray-900/50 to-transparent"></div>

<!-- Policy Lab Section -->
<section id="policies" class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-900/30">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Interactive Policy Lab</h2>
            <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
                Experiment with cross-culture numbering systems and custom policies
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
            <!-- Control Panel -->
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-lg transition-all duration-200 p-6">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Control Panel</h3>
                
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Numeric Value</label>
                        <input type="number" id="policyValue" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" value="12345678" oninput="executePolicyLab()">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Policy Identity</label>
                        <select id="policySelect" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" onchange="executePolicyLab()">
                            <!-- Populated via API -->
                        </select>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Threshold Override</label>
                            <input type="number" id="thresholdOverride" class="w-full px-4 py-2.5 text-sm bg-gray-50 dark:bg-gray-800/50 border border-gray-300 dark:border-gray-700/50 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200" placeholder="Inherit from policy" oninput="executePolicyLab()">
                        </div>
                        <div class="flex items-center space-x-2 pt-0 sm:pt-7">
                            <div class="flex items-center h-5">
                                <input type="checkbox" id="alwaysSuffixToggle" class="w-4 h-4 text-blue-600 dark:text-blue-400 bg-gray-100 dark:bg-gray-800 border-gray-300 dark:border-gray-700 rounded focus:ring-blue-500 focus:ring-2 cursor-pointer" onchange="executePolicyLab()">
                            </div>
                            <label for="alwaysSuffixToggle" class="text-sm font-medium text-gray-700 dark:text-gray-300 cursor-pointer select-none">Always Show Suffix</label>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Output Mode</label>
                        <div class="flex flex-wrap gap-3" id="policyModeContainer">
                            <button type="button" onclick="setPolicyMode('number')" id="btn-mode-number" class="mode-btn relative inline-flex items-center justify-center px-6 py-2.5 text-sm font-bold rounded-xl transition-all duration-300 border shadow-sm group active">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
