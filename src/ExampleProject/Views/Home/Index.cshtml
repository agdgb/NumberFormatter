@{
    ViewData["Title"] = "NumberFormatter Demo";
}

<h1>NumberFormatter Demo</h1>

<div>
    <button onclick="fetchData()">Get Financial Data</button>
    <button onclick="formatManual(1234567)">Format 1,234,567</button>
    <button onclick="formatManual(987654, 'EUR')">Format 987,654 as EUR</button>
    <button onclick="formatManual(555555, 'GBP')">Format 555,555 as GBP</button>
</div>

<div id="result" style="margin-top:20px; white-space:pre-wrap; background:#f5f5f5; padding:10px;">
    Click a button to see result.
</div>

@using NumberFormatter

<div class="row mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Company Metrics (Short Formatted)</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="p-3 border rounded bg-light">
                            <span class="text-muted small">Revenue</span>
                            <h3 class="mb-0 fw-bold">@((12345678.90m).ToShortString())</h3>
                            <small class="text-success">↑ 12.3%</small>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 border rounded bg-light">
                            <span class="text-muted small">Users</span>
                            <h3 class="mb-0 fw-bold">@((2456789).ToShortString(1))</h3>
                            <small class="text-success">↑ 5.6%</small>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 border rounded bg-light">
                            <span class="text-muted small">Downloads</span>
                            <h3 class="mb-0 fw-bold">@((987654).ToShortString(0))</h3>
                            <small class="text-warning">↗ 2.1%</small>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-3 border rounded bg-light">
                            <span class="text-muted small">Profit</span>
                            <h3 class="mb-0 fw-bold">@((3456789.12m).ToShortCurrencyString("USD"))</h3>
                            <small class="text-success">↑ 8.4%</small>
                        </div>
                    </div>
                </div>
                <hr />
                <p class="text-muted small mb-0">
                    Demonstrates <code>ToShortString()</code> and <code>ToShortCurrencyString()</code> with various decimal places.
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    async function fetchData() {
        const response = await fetch('/api/demo/data');
        const data = await response.json();
        document.getElementById('result').innerText = JSON.stringify(data, null, 2);
    }

    async function formatManual(value, currency) {
        let url = `/api/demo/manual/${value}`;
        if (currency) {
            url += `?currency=${currency}`;
        }
        const response = await fetch(url);
        const data = await response.json();
        document.getElementById('result').innerText = JSON.stringify(data, null, 2);
    }
</script>

<style>
    button {
        margin-right: 10px;
        padding: 8px 12px;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }
    button:hover {
        background-color: #0056b3;
    }
</style>