@addTagHelper *, NumberFormatter.AspNetCore

@{
    ViewData["Title"] = "NumberFormatter Showcase";
    Layout = "_Layout";
}

@using NumberFormatter

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">NumberFormatter Showcase</h1>
        <p class="lead text-muted">A beautiful demonstration of the features available in the
            <code>NumberFormatter</code> and <code>NumberFormatter.AspNetCore</code> libraries.</p>
    </div>

    <!-- 1. Extension Methods -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-gradient-primary text-white py-3">
            <h4 class="mb-0 fw-semibold"><i class="bi bi-code-square me-2"></i>1. Extension Methods</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="card-text text-secondary mb-4">
                Format numbers elegantly using modern extension methods like <code>ToShortString()</code> and
                <code>ToShortCurrencyString()</code> right off your numeric types.
            </p>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <div
                        class="p-4 border border-light-subtle rounded-4 bg-light text-center shadow-sm transition-hover">
                        <span class="text-secondary text-uppercase fw-semibold small d-block mb-2">Revenue</span>
                        <h3 class="mb-2 text-primary fw-bold">@((12345678.90m).ToShortString())</h3>
                        <span
                            class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i
                                class="bi bi-arrow-up-right me-1"></i>12.3%</span>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div
                        class="p-4 border border-light-subtle rounded-4 bg-light text-center shadow-sm transition-hover">
                        <span class="text-secondary text-uppercase fw-semibold small d-block mb-2">Active Users</span>
                        <h3 class="mb-2 text-primary fw-bold">@((2456789).ToShortString(1))</h3>
                        <span
                            class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i
                                class="bi bi-arrow-up-right me-1"></i>5.6%</span>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div
                        class="p-4 border border-light-subtle rounded-4 bg-light text-center shadow-sm transition-hover">
                        <span class="text-secondary text-uppercase fw-semibold small d-block mb-2">Downloads</span>
                        <h3 class="mb-2 text-primary fw-bold">@((987654).ToShortString(0))</h3>
                        <span
                            class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-2 py-1"><i
                                class="bi bi-arrow-right me-1"></i>2.1%</span>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div
                        class="p-4 border border-light-subtle rounded-4 bg-light text-center shadow-sm transition-hover">
                        <span class="text-secondary text-uppercase fw-semibold small d-block mb-2">Net Profit</span>
                        <h3 class="mb-2 text-primary fw-bold">@((3456789.12m).ToShortCurrencyString("USD"))</h3>
                        <span
                            class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i
                                class="bi bi-arrow-up-right me-1"></i>8.4%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Tag Helpers -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-success text-white py-3"
            style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
            <h4 class="mb-0 fw-semibold"><i class="bi bi-tags-fill me-2"></i>2. ASP.NET Core Tag Helpers</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="card-text text-secondary mb-4">
                Use intuitive HTML tags like <code>&lt;short-number&gt;</code> to render formatted data directly within
                your Razor views cleanly.
            </p>
            <div class="p-4 border border-success border-opacity-25 rounded-4 bg-success bg-opacity-10">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <div class="bg-dark rounded-3 p-3 shadow-sm">
                            <pre class="mb-0 text-light"><code class="language-html">&lt;short-number value="1234567.89m"
              format="currency"
              currency-code="USD"
              decimal-places="2"
              css-class="display-6 fw-bold text-success mb-0"&gt;
&lt;/short-number&gt;</code></pre>
                        </div>
                    </div>
                    <div class="col-md-5 text-center mt-4 mt-md-0 d-flex flex-column justify-content-center">
                        <span class="text-success text-uppercase fw-bold small mb-2"><i
                                class="bi bi-magic me-1"></i>Output</span>
                        <div class="p-4 bg-white rounded-4 shadow-sm border border-success border-opacity-25">
                            <short-number value="1234567.89m" format="currency" currency-code="USD" decimal-places="2"
                                css-class="display-6 fw-bold text-success mb-0"></short-number>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Dependency Injection -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-info text-dark py-3"
            style="background: linear-gradient(135deg, #0dcaf0 0%, #0bacce 100%);">
            <h4 class="mb-0 fw-semibold text-white"><i class="bi bi-box-seam-fill me-2"></i>3. Dependency Injection
                Service</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="card-text text-secondary mb-4">
                Inject <code>INumberFormatterService</code> directly into your controllers or view models via
                constructor injection for easy server-side formatting.
            </p>
            <div class="p-4 border border-info border-opacity-25 rounded-4 bg-info bg-opacity-10">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-uppercase fw-bold text-info-emphasis mb-3">Formatted in HomeController:</h6>
                        <ul class="list-group list-group-flush shadow-sm rounded-3">
                            <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                <div>
                                    <i class="bi bi-check-circle-fill text-info me-2"></i>
                                    <code>1,234,567.89m</code>
                                </div>
                                <strong><span class="fs-5">@ViewBag.FormattedValue</span></strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                <div>
                                    <i class="bi bi-check-circle-fill text-info me-2"></i>
                                    <code>9,876,543.21m (EUR)</code>
                                </div>
                                <strong><span class="fs-5">@ViewBag.FormattedCurrency</span></strong>
                            </li>
                        </ul>
                    </div>
                    <div class="col-md-6 mt-4 mt-md-0 d-flex align-items-center">
                        <div class="alert alert-info border-0 shadow-sm w-100 mb-0 d-flex align-items-center">
                            <i class="bi bi-info-circle-fill fs-3 me-3"></i>
                            <div>
                                <strong>Controller Injection</strong><br />
                                The values on the left were formatted purely in C# backend logic before rendering the
                                view.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. JSON Serialization API -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-warning text-dark py-3"
            style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);">
            <h4 class="mb-0 fw-semibold"><i class="bi bi-diagram-3-fill me-2"></i>4. ASP.NET Core JSON Integration</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="card-text text-secondary mb-4">
                Automatically format numeric properties returned through Web APIs using the built-in
                <code>ShortNumberJsonConverterFactory</code>.
            </p>

            <div class="row">
                <div class="col-md-4">
                    <div class="d-flex flex-column gap-3">
                        <button class="btn btn-warning btn-lg shadow-sm fw-semibold" onclick="fetchData()">
                            <i class="bi bi-cloud-download me-2"></i>Fetch API Data
                        </button>
                        <button class="btn btn-outline-secondary btn-lg fw-semibold"
                            onclick="formatManual(987654, 'EUR')">
                            <i class="bi bi-currency-euro me-2"></i>Format Custom Request
                        </button>
                        <div class="text-muted small mt-2">
                            <i class="bi bi-info-circle me-1"></i> These buttons hit standard API endpoints returning
                            JSON data formatted automatically by the converter.
                        </div>
                    </div>
                </div>
                <div class="col-md-8 mt-4 mt-md-0">
                    <div class="position-relative h-100">
                        <pre class="bg-dark text-light p-4 rounded-4 shadow-sm h-100 mb-0"
                            style="min-height: 200px; overflow-x: auto;"><code id="result" class="language-json">// Click a button to fetch API response...</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 5. Financial Playground -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-danger text-white py-3" style="background: linear-gradient(135deg, #dc3545 0%, #a71d2a 100%);">
            <h4 class="mb-0 fw-semibold"><i class="bi bi-wallet2 me-2"></i>5. Financial Systems Playground</h4>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="card-text text-secondary mb-4">
                Test the robust new <code>[BasisPoints]</code> and <code>[FractionPrice]</code> attribute deserialization mapping dynamically natively capturing JSON round-trip stability.
            </p>

            <div id="financialErrorBox" class="alert alert-danger d-none rounded-3 shadow-sm border-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <span id="financialErrorText" class="fw-semibold"></span>
            </div>

            <div class="row g-4">
                <div class="col-lg-5">
                    <h5 class="fw-bold text-danger-emphasis mb-3">Live JSON Input</h5>
                    <div class="mb-3 d-flex flex-wrap gap-2">
                        <div class="dropdown">
                          <button class="btn btn-outline-danger btn-sm dropdown-toggle fw-semibold" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-collection-play me-1"></i>Pre-built Presets
                          </button>
                          <ul class="dropdown-menu shadow-sm border-0" style="z-index:9999;">
                            <li><a class="dropdown-item" href="javascript:void(0)" onclick="loadPreset('golden')"><i class="bi bi-star-fill text-warning me-2"></i>Golden Standard</a></li>
                            <li><a class="dropdown-item" href="javascript:void(0)" onclick="loadPreset('negative')"><i class="bi bi-graph-down text-danger me-2"></i>Negative Edge Cases</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="loadPreset('error-bps')">Invalid BPS Syntax</a></li>
                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="loadPreset('error-frac')">Invalid Fraction Sizes</a></li>
                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="loadPreset('empty')">Empty / Null</a></li>
                          </ul>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm fw-semibold" onclick="copyDto()"><i class="bi bi-code-slash me-1"></i>Copy C# DTO</button>
                    </div>

                    <textarea id="financialInput" class="form-control font-monospace shadow-sm bg-light border-light-subtle rounded-3" rows="8">
{
  "spread": "125 bps",
  "treasuryPrice": "101 16/32",
  "rawAmount": "5432.10"
}</textarea>
                    
                    <button class="btn btn-danger w-100 mt-3 shadow-sm fw-bold border-0" style="background: linear-gradient(135deg, #dc3545 0%, #bd2130 100%);" onclick="executePlayground()"><i class="bi bi-braces me-2"></i>Execute Model Binding</button>
                </div>

                <div class="col-lg-7">
                     <h5 class="fw-bold text-success-emphasis mb-3 d-flex justify-content-between align-items-center">
                         API Serialization Response 
                         <span id="matchBadge" class="badge bg-secondary bg-opacity-25 text-secondary border border-secondary border-opacity-25 rounded-pill fw-normal fs-6 px-3">Idle</span>
                     </h5>
                     <div class="position-relative h-100">
                        <pre id="financialResult" class="bg-dark text-light p-4 rounded-4 shadow-sm mb-0 font-monospace" style="min-height: 250px; overflow-x: auto;">// Hit Execute to map via ASP.NET...</pre>
                     </div>
                </div>
            </div>

            <!-- Insights Component -->
            <div id="financialInsights" class="mt-4 p-4 border border-danger border-opacity-25 rounded-4 bg-danger bg-opacity-10 d-none">
                <h6 class="text-uppercase fw-bold text-danger-emphasis mb-3"><i class="bi bi-lightbulb-fill text-warning me-2"></i>Verification Layer Insights</h6>
                <div class="row align-items-center">
                    <div class="col-md-5 mb-3 mb-md-0">
                       <span class="d-block small text-muted text-uppercase fw-semibold mb-1">Parsed Fraction (Decimal representation)</span>
                       <h4 id="fractionDecimalDisplay" class="text-danger fw-bold mb-0"></h4>
                    </div>
                    <div class="col-md-7 border-start border-danger border-opacity-25 ps-md-4">
                       <span class="d-block small text-muted text-uppercase fw-semibold mb-1">C# ToCheckWords() Extractor</span>
                       <span id="wordsDisplay" class="fs-5 text-dark"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .15) !important;
    }
</style>

@section Scripts {
    <script>
        async function fetchData() {
            try {
                const resultBlock = document.getElementById('result');
                resultBlock.innerText = "Loading data...";
                resultBlock.style.opacity = '0.5';

                const response = await fetch('/api/demo/data');
                const data = await response.json();

                resultBlock.innerText = JSON.stringify(data, null, 2);
            } catch (e) {
                document.getElementById('result').innerText = "Error loading data: " + e.message;
            } finally {
                document.getElementById('result').style.opacity = '1';
            }
        }

        async function formatManual(value, currency) {
            try {
                const resultBlock = document.getElementById('result');
                resultBlock.innerText = "Loading data...";
                resultBlock.style.opacity = '0.5';

                let url = `/api/demo/manual/${value}`;
                if (currency) {
                    url += `?currency=${currency}`;
                }
                const response = await fetch(url);
                const data = await response.json();

                resultBlock.innerText = JSON.stringify(data, null, 2);
            } catch (e) {
                document.getElementById('result').innerText = "Error loading data: " + e.message;
            } finally {
                document.getElementById('result').style.opacity = '1';
            }
        }

        function loadPreset(type) {
            const el = document.getElementById('financialInput');
            if (type === 'golden') el.value = '{\n  "spread": "125 bps",\n  "treasuryPrice": "101 16/32",\n  "rawAmount": "5432.10"\n}';
            if (type === 'negative') el.value = '{\n  "spread": "-50 bps",\n  "treasuryPrice": "99 1/32",\n  "rawAmount": "-1000.00"\n}';
            if (type === 'error-bps') el.value = '{\n  "spread": "12x bps",\n  "treasuryPrice": "100"\n}';
            if (type === 'error-frac') el.value = '{\n  "spread": "100",\n  "treasuryPrice": "100 99/32"\n}';
            if (type === 'empty') el.value = '{\n  "spread": null,\n  "treasuryPrice": null,\n  "rawAmount": null\n}';
        }

        function copyDto() {
            navigator.clipboard.writeText(`public class FinancialPlaygroundRequest
{
    [BasisPoints] public decimal? Spread { get; set; }
    [FractionPrice(32)] public decimal? TreasuryPrice { get; set; }
    public decimal? RawAmount { get; set; }
}`);
            alert("DTO structure copied directly to clipboard!");
        }

        async function executePlayground() {
            const inputTxt = document.getElementById('financialInput').value;
            const resEl = document.getElementById('financialResult');
            const errBox = document.getElementById('financialErrorBox');
            const errTxt = document.getElementById('financialErrorText');
            const badge = document.getElementById('matchBadge');
            const insightsBox = document.getElementById('financialInsights');
            const fractionDisp = document.getElementById('fractionDecimalDisplay');
            const wordsDisp = document.getElementById('wordsDisplay');

            errBox.classList.add('d-none');
            insightsBox.classList.add('d-none');
            resEl.innerText = "Processing...";
            resEl.style.opacity = '0.5';

            try {
                let parsedInput;
                try {
                     parsedInput = JSON.parse(inputTxt);
                } catch(e) {
                     throw new Error("Syntax Error: Input content must be structurally valid JSON.");
                }

                const response = await fetch('/api/demo/financial', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: inputTxt
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || "A fatal server error occurred processing bindings.");
                }

                resEl.innerText = JSON.stringify(data, null, 2);

                if (data.roundtripMatch) {
                    badge.className = "badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill fw-normal fs-6 px-3";
                    badge.innerHTML = "<i class='bi bi-check-circle-fill me-2'></i>Perfect System.Text.Json Roundtrip";
                } else {
                    badge.className = "badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill fw-normal fs-6 px-3";
                    badge.innerHTML = "<i class='bi bi-exclamation-circle-fill me-2'></i>Differs from Input";
                }

                fractionDisp.innerText = data.parsed.treasuryPrice !== null ? data.parsed.treasuryPrice : "N/A";
                wordsDisp.innerText = data.wordsOutput || "N/A";
                insightsBox.classList.remove('d-none');

            } catch (e) {
                resEl.innerText = "// Exception caught by pipeline framework.";
                errTxt.innerText = e.message;
                errBox.classList.remove('d-none');
                badge.className = "badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill fw-normal fs-6 px-3";
                badge.innerHTML = "<i class='bi bi-x-circle-fill me-2'></i>Deserialization Failed";
            } finally {
                resEl.style.opacity = '1';
            }
        }
    </script>
}