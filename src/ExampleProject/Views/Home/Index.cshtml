@addTagHelper *, HumanNumbers.AspNetCore

@{
    ViewData["Title"] = "HumanNumbers Feature Showcase";
    Layout = "_Layout";
}

@using HumanNumbers
@using System.Globalization

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">HumanNumbers Showcase</h1>
        <p class="lead text-muted">Exhaustive technical demonstration of the <code>HumanNumbers</code> v2.0 ecosystem.</p>
        <div class="d-flex justify-content-center gap-2 mt-3">
             <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">.NET 8.0 / 10.0+</span>
             <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">Zero Allocation</span>
             <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3 py-2">Culture Aware</span>
        </div>
    </div>

    <!-- 1. The Interactive Lab (Roman & Bytes) -->
    <div class="row g-4 mb-5">
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient-primary text-white py-3">
                    <h5 class="mb-0 fw-semibold"><i class="bi bi-hash me-2"></i>Roman Numeral Lab</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small">Supports integers from 1 to 3,999.</p>
                    <div class="input-group mb-3">
                        <input type="number" id="romanInput" class="form-control form-control-lg border-primary border-opacity-25" value="2024" min="1" max="3999">
                        <button class="btn btn-primary px-4" onclick="convertRoman()"><i class="bi bi-magic me-2"></i>Convert</button>
                    </div>
                    <div id="romanResultContainer" class="p-3 bg-light rounded-3 text-center d-none">
                        <span class="text-uppercase text-muted small d-block mb-1">Roman Output</span>
                        <h2 id="romanOutput" class="display-5 fw-bold text-primary mb-0"></h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-success text-white py-3" style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
                    <h5 class="mb-0 fw-semibold"><i class="bi bi-hdd-fill me-2"></i>Byte Size Formatter</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small">Toggle between SI (Decimal) and IEC (Binary) standards.</p>
                    <div class="input-group mb-3">
                        <input type="number" id="byteInput" class="form-control form-control-lg border-success border-opacity-25" value="5368709120" min="0">
                        <div class="input-group-text bg-white border-success border-opacity-25">
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="binaryToggle">
                                <label class="form-check-label small ms-2" for="binaryToggle">IEC / Binary</label>
                            </div>
                        </div>
                        <button class="btn btn-success px-4" onclick="convertBytes()"><i class="bi bi-cpu me-2"></i>Scale</button>
                    </div>
                    <div id="byteResultContainer" class="p-3 bg-light rounded-3 text-center d-none">
                        <span class="text-uppercase text-muted small d-block mb-1" id="byteLabel">Human-Readable Size</span>
                        <h2 id="byteOutput" class="display-5 fw-bold text-success mb-0"></h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Robust Parsing Lab -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-info text-white py-3" style="background: linear-gradient(135deg, #0dcaf0 0%, #0bacce 100%);">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-arrow-down-left-circle-fill me-2"></i>Robust Parsing Lab (Round-Trip)</h5>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="card-text text-secondary mb-4">
                Demonstrating <code>HumanNumber.Parse</code>. Input a formatted string (even with suffixes or culture-specific symbols) and see it resolve back to a decimal.
            </p>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold text-info-emphasis">Formatted Input</label>
                    <input type="text" id="parseInput" class="form-control form-control-lg font-monospace" value="1.5M" placeholder="e.g. 1.5M, $50k, 1,250.50">
                    <div class="mt-2 d-flex gap-2">
                        <button class="btn btn-sm btn-outline-info" onclick="setParsePreset('1.5M')">1.5M</button>
                        <button class="btn btn-sm btn-outline-info" onclick="setParsePreset('$50.25k')">$50.25k</button>
                        <button class="btn btn-sm btn-outline-info" onclick="setParsePreset('1,5k', 'fr-FR')">1,5k (FR)</button>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-info-emphasis">Culture</label>
                    <select id="parseCulture" class="form-select form-select-lg">
                        <option value="">Invariant / US</option>
                        <option value="fr-FR">French (fr-FR)</option>
                        <option value="de-DE">German (de-DE)</option>
                        <option value="en-GB">British (en-GB)</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-info text-white btn-lg w-100 fw-bold" onclick="executeParse()"><i class="bi bi-play-fill me-1"></i>Resolve</button>
                </div>
            </div>
            <div id="parseResultContainer" class="mt-4 p-4 border border-info border-opacity-25 rounded-4 bg-info bg-opacity-10 d-none text-center">
                <i class="bi bi-check-circle-fill text-info fs-3 mb-2 d-block"></i>
                <span class="text-uppercase text-muted small fw-semibold">Resolved Decimal Value</span>
                <h3 id="parseOutput" class="fw-bold text-info-emphasis mb-0 mt-1"></h3>
            </div>
        </div>
    </div>

    <!-- 3. Attribute & JSON Showcase -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-warning text-dark py-3" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-diagram-3-fill me-2"></i>Attribute Mapping Showcase</h5>
        </div>
        <div class="card-body p-4 bg-white">
            <div class="row align-items-center mb-4">
                <div class="col-md-8">
                    <p class="card-text text-secondary mb-0">
                        See how <code>[HumanNumberFormat]</code> and <code>[NoHumanFormat]</code> control serialization in a single API response.
                    </p>
                </div>
                <div class="col-md-4 text-md-end">
                    <button class="btn btn-warning fw-bold px-4 shadow-sm" onclick="fetchShowcase()"><i class="bi bi-cloud-download-fill me-2"></i>Fetch Showcase JSON</button>
                </div>
            </div>
            
            <div class="row g-4">
                <div class="col-lg-6">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Response Preview</h6>
                    <div class="position-relative">
                        <pre class="bg-dark text-light p-4 rounded-4 shadow-sm font-monospace mb-0" style="min-height: 250px;"><code id="showcaseOutput" class="language-json">// Click the button to see attribute-driven JSON...</code></pre>
                    </div>
                </div>
                <div class="col-lg-6">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Model Configuration</h6>
                    <div class="bg-light p-4 rounded-4 border border-light-subtle h-100">
                        <div class="small mb-3"><i class="bi bi-code-slash text-warning me-2"></i><strong>ShowcaseModel.cs</strong></div>
                        <ul class="list-group list-group-flush small bg-transparent">
                            <li class="list-group-item bg-transparent px-0 py-2 border-light-subtle">
                                <code class="text-primary">[HumanNumberFormat(isCurrency: true)]</code><br/>
                                <span class="text-muted">TotalValue: 1,550,000.50 &rarr; "$1.55M"</span>
                            </li>
                            <li class="list-group-item bg-transparent px-0 py-2 border-light-subtle">
                                <code class="text-danger">[NoHumanFormat]</code><br/>
                                <span class="text-muted">SystemInternalId: 9876543210 &rarr; 9876543210</span>
                            </li>
                            <li class="list-group-item bg-transparent px-0 py-2 border-light-subtle">
                                <code class="text-secondary">(Unmarked)</code><br/>
                                <span class="text-muted">ActiveTransactions: 1250 &rarr; "1.25k"</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. Performance & Benchmarks -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-speedometer2 me-2"></i>Performance & Benchmarks</h5>
        </div>
        <div class="card-body p-4 bg-white">
            <p class="text-secondary mb-4">HumanNumbers is optimized for zero-allocation hot paths using <code>Span&lt;char&gt;</code>. These metrics are recorded on a generic production machine.</p>
            <div class="table-responsive">
                <table class="table table-hover align-middle border border-light-subtle rounded-3 overflow-hidden">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Feature</th>
                            <th>Execution Time</th>
                            <th>Allocated Memory</th>
                            <th class="pe-4">Optimization Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4"><code>ToHuman()</code> (Scaling)</td>
                            <td><span class="badge bg-success bg-opacity-10 text-success fw-bold">~85 ns</span></td>
                            <td><span class="text-success fw-bold">0 B</span></td>
                            <td class="pe-4 fw-semibold text-muted">Zero-Allocation <i class="bi bi-lightning-charge-fill text-warning ms-1"></i></td>
                        </tr>
                        <tr>
                            <td class="ps-4"><code>ToHumanCurrency()</code></td>
                            <td><span class="badge bg-success bg-opacity-10 text-success fw-bold">~110 ns</span></td>
                            <td><span class="text-success fw-bold">0 B</span></td>
                            <td class="pe-4 fw-semibold text-muted">Zero-Allocation <i class="bi bi-lightning-charge-fill text-warning ms-1"></i></td>
                        </tr>
                        <tr>
                            <td class="ps-4"><code>HumanNumber.Parse()</code></td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary fw-bold">~120 ns</span></td>
                            <td><span class="text-secondary fw-bold">32 B</span></td>
                            <td class="pe-4 fw-semibold text-muted">Optimized <i class="bi bi-check-circle-fill text-primary ms-1"></i></td>
                        </tr>
                        <tr>
                            <td class="ps-4">Roman Numerals</td>
                            <td><span class="badge bg-success bg-opacity-10 text-success fw-bold">~45 ns</span></td>
                            <td><span class="text-success fw-bold">0 B</span></td>
                            <td class="pe-4 fw-semibold text-muted">Zero-Allocation <i class="bi bi-lightning-charge-fill text-warning ms-1"></i></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 5. Financial Systems Playground (Existing) -->
    <div class="card shadow-sm border-0 mb-5 rounded-4 overflow-hidden">
        <div class="card-header bg-danger text-white py-3" style="background: linear-gradient(135deg, #dc3545 0%, #a71d2a 100%);">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-wallet2 me-2"></i>Interactive Financial Playground</h5>
        </div>
        <div class="card-body p-4 bg-white">
            <!-- Content same as before but slightly refined UI -->
             <div id="financialErrorBox" class="alert alert-danger d-none rounded-3 shadow-sm border-0 mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <span id="financialErrorText" class="fw-semibold"></span>
            </div>

            <div class="row g-4">
                <div class="col-lg-5">
                    <h6 class="fw-bold text-danger-emphasis mb-3">Live JSON Submission</h6>
                    <div class="mb-3 d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-danger btn-sm" onclick="loadPreset('golden')">Golden Standard</button>
                        <button class="btn btn-outline-danger btn-sm" onclick="loadPreset('negative')">Negative Case</button>
                    </div>
                    <textarea id="financialInput" class="form-control font-monospace shadow-sm bg-light border-light-subtle rounded-3" rows="7">
{
  "spread": "125 bps",
  "treasuryPrice": "101 16/32",
  "rawAmount": "5432.10"
}</textarea>
                    <button class="btn btn-danger w-100 mt-3 shadow-sm fw-bold border-0" onclick="executePlayground()"><i class="bi bi-braces me-1"></i>Run Model Binding</button>
                </div>

                <div class="col-lg-7">
                     <h6 class="fw-bold text-success-emphasis mb-3 d-flex justify-content-between align-items-center">
                         ASP.NET Serialization Roundtrip 
                         <span id="matchBadge" class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill fw-normal fs-6 px-3">Idle</span>
                     </h6>
                     <pre id="financialResult" class="bg-dark text-light p-4 rounded-4 shadow-sm mb-0 font-monospace" style="min-height: 200px; overflow-x: auto;">// Hit Run to map via ASP.NET...</pre>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function convertRoman() {
            const val = document.getElementById('romanInput').value;
            const resContainer = document.getElementById('romanResultContainer');
            const output = document.getElementById('romanOutput');
            
            try {
                const response = await fetch(`/api/demo/roman/${val}`);
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);

                output.innerText = data.roman;
                resContainer.classList.remove('d-none');
            } catch (e) {
                alert("Roman Error: " + e.message);
            }
        }

        async function convertBytes() {
            const val = document.getElementById('byteInput').value;
            const binary = document.getElementById('binaryToggle').checked;
            const resContainer = document.getElementById('byteResultContainer');
            const output = document.getElementById('byteOutput');
            const label = document.getElementById('byteLabel');
            
            try {
                const response = await fetch(`/api/demo/bytes/${val}?binary=${binary}`);
                const data = await response.json();
                
                label.innerText = data.type;
                output.innerText = data.formatted;
                resContainer.classList.remove('d-none');
            } catch (e) {
                alert("Byte Error: " + e.message);
            }
        }

        async function executeParse() {
            const input = document.getElementById('parseInput').value;
            const culture = document.getElementById('parseCulture').value;
            const resContainer = document.getElementById('parseResultContainer');
            const output = document.getElementById('parseOutput');
            
            try {
                const url = `/api/demo/parse?input=${encodeURIComponent(input)}&culture=${culture}`;
                const response = await fetch(url);
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);

                output.innerText = data.parsedValue;
                resContainer.classList.remove('d-none');
            } catch (e) {
                alert(e.message);
            }
        }

        function setParsePreset(txt, culture = '') {
            document.getElementById('parseInput').value = txt;
            document.getElementById('parseCulture').value = culture;
            executeParse();
        }

        async function fetchShowcase() {
            const output = document.getElementById('showcaseOutput');
            output.innerText = "Fetching showcase data...";
            output.style.opacity = '0.5';

            try {
                const response = await fetch('/api/demo/showcase');
                const data = await response.json();
                output.innerText = JSON.stringify(data, null, 2);
            } catch (e) {
                output.innerText = "Error: " + e.message;
            } finally {
                output.style.opacity = '1';
            }
        }

        // Financial Playground logic (preserved from previous version)
        function loadPreset(type) {
            const el = document.getElementById('financialInput');
            if (type === 'golden') el.value = '{\n  "spread": "125 bps",\n  "treasuryPrice": "101 16/32",\n  "rawAmount": "5432.10"\n}';
            if (type === 'negative') el.value = '{\n  "spread": "-50 bps",\n  "treasuryPrice": "99 1/32",\n  "rawAmount": "-1000.00"\n}';
        }

        async function executePlayground() {
             const inputTxt = document.getElementById('financialInput').value;
             const resEl = document.getElementById('financialResult');
             const badge = document.getElementById('matchBadge');
             const errBox = document.getElementById('financialErrorBox');
             const errTxt = document.getElementById('financialErrorText');

             errBox.classList.add('d-none');
             resEl.innerText = "Processing binding...";
             
             try {
                const response = await fetch('/api/demo/financial', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: inputTxt
                });
                const data = await response.json();
                if (!response.ok) throw new Error(data.error);

                resEl.innerText = JSON.stringify(data, null, 2);
                if (data.roundtripMatch) {
                    badge.className = "badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill fw-normal fs-6 px-3";
                    badge.innerText = "Perfect Roundtrip";
                } else {
                    badge.className = "badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill fw-normal fs-6 px-3";
                    badge.innerText = "Content Changed";
                }
             } catch (e) {
                errTxt.innerText = e.message;
                errBox.classList.remove('d-none');
                resEl.innerText = "// Deserialization Error";
                badge.className = "badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill fw-normal fs-6 px-3";
                badge.innerText = "Fatal Error";
             }
        }
    </script>
}